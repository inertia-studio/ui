        "class-variance-authority": "^0.7.1"
    },
    "peerDependencies": {
        "react": "^19.0.0",
        "react-dom": "^19.0.0",
        "@inertiajs/react": "^3.0.0",
        "vue": "^3.5.0",
        "@inertiajs/vue3": "^3.0.0",
