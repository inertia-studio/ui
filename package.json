        "tailwindcss": "^4.0.0"
    },
    "peerDependenciesMeta": {
        "react": { "optional": true },
        "react-dom": { "optional": true },
        "@inertiajs/react": { "optional": true },
        "vue": { "optional": true },
        "@inertiajs/vue3": { "optional": true },
        "svelte": { "optional": true },
        "@inertiajs/svelte": { "optional": true }
    },
    "devDependencies": {
        "typescript": "^5.7.2",
        "@types/react": "^19.2.0",
        "@types/react-dom": "^19.2.0"
    },
