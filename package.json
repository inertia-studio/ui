{
    "$schema": "https://www.schemastore.org/package.json",
    "name": "@inertia-studio/ui",
    "version": "0.2.4",
    "description": "UI components for Inertia Studio admin panels — React, Vue, and Svelte.",
    "type": "module",
    "exports": {
        "./react": "./src/react/index.ts",
        "./vue": "./src/vue/index.ts",
        "./svelte": "./src/svelte/index.ts",
        "./vite": "./src/vite.mjs",
        "./studio.css": {
            "style": "./src/studio.css",
            "default": "./src/studio.css"
        }
    },
    "files": [
        "src"
    ],
    "scripts": {
        "types:check": "tsc --noEmit"
    },
    "dependencies": {
        "clsx": "^2.1.1",
